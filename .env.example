# Required
AI_MODEL=your-model-name
AI_API_FORMAT=openai_responses
AI_API_URL=https://your-api-host.example/v1/responses
AI_API_HEADERS={"Authorization":"Bearer YOUR_API_KEY"}

# Optional extra request fields merged into the request body
# AI_API_BODY={"temperature":0.2}

# Optional: trust a custom CA bundle for TLS verification.
# Needed when a corporate proxy / secure web gateway (e.g. Netskope, Zscaler)
# intercepts HTTPS and re-signs with its own root CA, which Python's bundled
# certifi store does not trust. Export the corporate root CA to a .pem and
# point this at it, e.g. on macOS:
#   security find-certificate -a -c "goskope" -p /Library/Keychains/System.keychain > ca.pem
# REQUESTS_CA_BUNDLE=/absolute/path/to/ca.pem

# Example for APIs that use the OpenAI Responses format
# AI_MODEL=your-model-name
# AI_API_FORMAT=openai_responses
# AI_API_URL=https://your-api-host.example/v1/responses
# AI_API_HEADERS={"Authorization":"Bearer YOUR_API_KEY"}

# Example for APIs that use an OpenAI-style Chat Completions format
# AI_MODEL=your-model-name
# AI_API_FORMAT=openai_chat
# AI_API_URL=https://your-api-host.example/v1/chat/completions
# AI_API_HEADERS={"Authorization":"Bearer YOUR_API_KEY"}

# Example for APIs that use an Anthropic Messages format
# AI_MODEL=your-model-name
# AI_API_FORMAT=anthropic_messages
# AI_API_URL=https://your-api-host.example/v1/messages
# AI_API_HEADERS={"x-api-key":"YOUR_API_KEY","anthropic-version":"2023-06-01"}
